# --- Green Node (VNG MaaS) LLM gateway, OpenAI-compatible ---
LLM_BASE_URL=https://maas-llm-aiplatform-hcm.api.vngcloud.vn/v1
LLM_API_KEY=your-api-key-here
LLM_MODEL=google/gemma-4-31b-it

# --- Embeddings (same gateway) ---
# Changing these on a database that already holds vectors is NOT a pure config
# change: stored embeddings are model- and dimension-specific. After editing,
# run `uv run python -m backend.app.cli reembed` to re-embed existing chunks;
# until then the app fails fast and ingestion is rejected (409).
EMBEDDING_MODEL=gemini/gemini-embedding-001
EMBEDDING_DIM=3072

# --- Database (dedicated pgvector container, docker-compose.yml) ---
DATABASE_URL=postgresql+psycopg://rag:rag_password@localhost:5434/rag_chat

# --- Auth ---
JWT_SECRET=change-me-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# --- App ---
CORS_ORIGINS=http://localhost:3000
